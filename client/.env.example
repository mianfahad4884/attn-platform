# ── ATTN FRONTEND ENVIRONMENT VARIABLES ───────────────────────────────────────

# The URL of your deployed backend API (or localhost for dev)
# In Netlify, this should point to your own domain.
VITE_API_URL=http://localhost:3001

# The CPX Research App ID (get this from the CPX Publisher Dashboard)
# If provided, the Verify page will render the real CPX Offerwall iframe.
# If absent, the Verify page will simulate a 30s countdown.
VITE_CPX_APP_ID=...
