# ── Database ──────────────────────────────────────────────────────────────────
# The connection string for your Postgres database (Neon, Supabase, etc.)
# If absent, the app will fail to start.
DATABASE_URL=postgres://user:password@hostname/dbname

# ── Payments ──────────────────────────────────────────────────────────────────
# Stripe secret key for fiat payouts (get this from Stripe Dashboard)
# If absent, fiat payouts are simulated and logged to the console.
STRIPE_SECRET_KEY=sk_test_...

# Coinbase Commerce API key for crypto payouts (get from Coinbase Settings)
# If absent, crypto payouts are simulated and logged to the console.
COINBASE_COMMERCE_API_KEY=...

# ── Security ──────────────────────────────────────────────────────────────────
# reCAPTCHA v3 secret key (get from Google reCAPTCHA Admin Console)
# If absent, reCAPTCHA validation will be skipped.
RECAPTCHA_SECRET_KEY=...

# FingerprintJS Pro Secret API Key (get from Fingerprint Dashboard)
# If absent, hardware fingerprint validation is bypassed.
FINGERPRINTJS_API_KEY=...

# ── Communication ─────────────────────────────────────────────────────────────
# Resend API key for transactional emails (get from resend.com)
# If absent, emails are mocked and logged to the console.
EMAIL_API_KEY=re_...

# ── Identity ──────────────────────────────────────────────────────────────────
# API key for your KYC provider (e.g. Stripe Identity, Persona)
# If absent, KYC gates are completely bypassed and everyone is assumed verified.
KYC_PROVIDER_API_KEY=...

# ── Queues ────────────────────────────────────────────────────────────────────
# Redis connection string for BullMQ (get from Upstash, Redis Labs, etc.)
# Note: Netlify serverless functions cannot currently process BullMQ jobs persistently.
# This variable is for future scalability when deployed to Render/Railway.
REDIS_URL=rediss://...
