# ── ATTN PRODUCTION ENVIRONMENT VARIABLES ─────────────────────────────────────
# Rename this file to .env.production or copy these directly into the Netlify Dashboard.

NODE_ENV=production
FRONTEND_URL=https://your-production-domain.com

# ── Database ──────────────────────────────────────────────────────────────────
# MUST be a pooled connection string (e.g. Neon Serverless or Supabase pgbouncer port 6543)
DATABASE_URL=postgres://user:password@hostname:6543/dbname?pgbouncer=true

# ── Ad Network / Offerwall ────────────────────────────────────────────────────
CPX_API_KEY=your_cpx_research_publisher_secret_key

# ── Error Monitoring ──────────────────────────────────────────────────────────
SENTRY_DSN=https://...

# ── Payments ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
COINBASE_COMMERCE_API_KEY=...

# ── Security ──────────────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=...
FINGERPRINTJS_API_KEY=...

# ── Communication & Identity ──────────────────────────────────────────────────
EMAIL_API_KEY=re_...
KYC_PROVIDER_API_KEY=...
